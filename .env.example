# Apeksha AI - Environment Configuration
# Copy this to .env and fill in values

# ═══════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════
APEKSHA_WORKSPACE=./workspace
OLLAMA_HOST=http://localhost:11434

# ═══════════════════════════════════════════════════════════════
# OPTIONAL - Payments (choose one)
# ═══════════════════════════════════════════════════════════════

# Stripe (International)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# ═══════════════════════════════════════════════════════════════
# OPTIONAL - Authentication (if using external provider)
# ═══════════════════════════════════════════════════════════════

# Clerk (recommended for production)
# CLERK_SECRET_KEY=sk_xxxxx
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_xxxxx

# ═══════════════════════════════════════════════════════════════
# OPTIONAL - Production Database
# ═══════════════════════════════════════════════════════════════

# PostgreSQL (replace JSON file storage)
# DATABASE_URL=postgresql://user:pass@localhost:5432/apeksha

# ═══════════════════════════════════════════════════════════════
# OPTIONAL - Analytics
# ═══════════════════════════════════════════════════════════════

# PostHog (product analytics)
# POSTHOG_API_KEY=phc_xxxxx
